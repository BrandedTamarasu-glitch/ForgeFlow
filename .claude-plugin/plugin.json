{
  "name": "Forgeflow",
  "version": "4.2.0",
  "description": "6-agent review and development Forgeflow for Claude Code — full lifecycle from discussion through shipping. Code quality, security, UX, program management, architectural oversight, and product management across specialized agents. V4.2 adds /handoff, /review-auto, /fleet, /ui-iterate, /sync-upstream, /forgeflow-health, /forgeflow-metrics, /forgeflow-learnings plus cross-project pattern memory.",
  "author": {
    "name": "ForgeflowAI",
    "url": "https://github.com/ForgeflowAI"
  },
  "homepage": "https://github.com/ForgeflowAI/Forgeflow",
  "repository": {
    "type": "git",
    "url": "https://github.com/ForgeflowAI/Forgeflow.git"
  },
  "license": "Private",
  "keywords": [
    "claude-code",
    "review",
    "sub-agents",
    "workflow",
    "code-quality",
    "security-review",
    "multi-agent"
  ],
  "components": {
    "agents": "agents/",
    "commands": "commands/",
    "hooks": "hooks/",
    "templates": "templates/",
    "project-rules": "project-rules/",
    "forgeflow-patterns": "forgeflow-patterns/"
  },
  "install": {
    "destinations": {
      "agents/*.md": "~/.claude/agents/",
      "commands/*.md": "~/.claude/commands/",
      "commands/*/*.md": "~/.claude/commands/",
      "hooks/*.js": "~/.claude/hooks/",
      "templates/*": "~/.claude/templates/",
      "project-rules/*.md": "~/.claude/project-rules/",
      "forgeflow-patterns/*.md": "~/.claude/forgeflow-patterns/"
    },
    "preserve": [
      "~/.claude/agents/custom-*.md"
    ],
    "post-install": {
      "description": "After install, add the four hooks to ~/.claude/settings.json PostToolUse array. See README Installation section.",
      "hooks-to-wire": [
        "forgeflow-gate.js",
        "forgeflow-context-monitor.js",
        "forgeflow-telemetry.js"
      ],
      "statusline-to-wire": "forgeflow-statusline.js"
    }
  },
  "claude-code": {
    "min-version": "1.0.0"
  }
}
