{
  "name": "Forgeflow",
  "version": "4.3.71",
  "description": "Forgeflow lean guidance adapter for Codex. Installs shared commands, hooks, and runtime helpers from this repository.",
  "repository": {
    "type": "git",
    "url": "https://github.com/BrandedTamarasu-glitch/ForgeFlow.git"
  },
  "license": "MIT",
  "components": {
    "commands": "commands/",
    "hooks": "hooks/",
    "runtime-helpers": "scripts/forgeflow/",
    "skills": ".openclaw/skills/"
  },
  "hooks": {
    "SessionStart": [
      "node hooks/forgeflow-lean-activate.js"
    ],
    "UserPromptSubmit": [
      "node hooks/forgeflow-lean-activate.js"
    ]
  }
}
