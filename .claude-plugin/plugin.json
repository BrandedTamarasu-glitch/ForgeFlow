{
  "name": "Forgeflow",
  "version": "4.3.37",
  "description": "End-to-end AI software delivery workflow for Claude Code and Codex. Forgeflow covers discussion, research, planning, implementation, review, verification, and shipping with focused agents.",
  "author": {
    "name": "BrandedTamarasu-glitch",
    "url": "https://github.com/BrandedTamarasu-glitch"
  },
  "homepage": "https://github.com/BrandedTamarasu-glitch/ForgeFlow",
  "repository": {
    "type": "git",
    "url": "https://github.com/BrandedTamarasu-glitch/ForgeFlow.git"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "review",
    "sub-agents",
    "workflow",
    "code-quality",
    "security-review",
    "multi-agent"
  ],
  "components": {
    "agents": "agents/",
    "commands": "commands/",
    "hooks": "hooks/",
    "templates": "templates/",
    "project-rules": "project-rules/",
    "forgeflow-patterns": "forgeflow-patterns/",
    "runtime-helpers": "scripts/forgeflow/"
  },
  "install": {
    "destinations": {
      "agents/*.md": "~/.claude/agents/",
      "agents/_shared/*.md": "~/.claude/agents/_shared/",
      "commands/*.md": "~/.claude/commands/",
      "commands/*/*.md": "~/.claude/commands/",
      "hooks/*.js": "~/.claude/hooks/",
      "templates/*": "~/.claude/templates/",
      "project-rules/*.md": "~/.claude/project-rules/",
      "forgeflow-patterns/*.md": "~/.claude/forgeflow-patterns/",
      "scripts/forgeflow/*.js": "~/.claude/forgeflow/scripts/forgeflow/",
      "scripts/forgeflow/*.sh": "~/.claude/forgeflow/scripts/forgeflow/"
    },
    "preserve": [
      "~/.claude/agents/custom-*.md"
    ],
    "exclude": [
      "scripts/forgeflow/test-*"
    ],
    "post-install": {
      "description": "After install, wire the PostToolUse hooks and statusline in ~/.claude/settings.json, then restart Claude Code so commands and hooks reload.",
      "hooks-to-wire": [
        "forgeflow-gate.js",
        "forgeflow-context-monitor.js",
        "forgeflow-telemetry.js"
      ],
      "statusline-to-wire": "forgeflow-statusline.js",
      "verify": [
        "/forgeflow-version",
        "/forgeflow-health"
      ],
      "manual-settings": {
        "statusLine.command": "node \"~/.claude/hooks/forgeflow-statusline.js\"",
        "PostToolUse": [
          "node \"~/.claude/hooks/forgeflow-context-monitor.js\"",
          "node \"~/.claude/hooks/forgeflow-gate.js\"",
          "node \"~/.claude/hooks/forgeflow-telemetry.js\""
        ]
      }
    }
  },
  "claude-code": {
    "min-version": "1.0.0"
  }
}
